ENDGAME_RELEASE_ENABLED=true
RELEASE_FREEZE_ENABLED=true
BOARD_PACK_ENABLED=true
DOSSIER_EXPORT_ENABLED=true
DOSSIER_INCLUDE_CUSTOMER_DATA=false
