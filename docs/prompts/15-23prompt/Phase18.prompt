## Suggested Commands

```bash
# Create branch
git checkout -b fix/cloudflare-multi-environment-separation

# Create directories
mkdir -p infra/cloudflare/environments

# After writing files
chmod +x infra/cloudflare/scripts/scan-cloudflare-environment-boundaries.sh
bash -n infra/cloudflare/scripts/scan-cloudflare-environment-boundaries.sh
infra/cloudflare/scripts/scan-cloudflare-environment-boundaries.sh --help
infra/cloudflare/scripts/scan-cloudflare-environment-boundaries.sh --markdown
infra/cloudflare/scripts/scan-cloudflare-environment-boundaries.sh --json | python3 -m json.tool

# Verify no prod domains in dev/staging
grep -E '\.zeaz\.dev' infra/cloudflare/environments/dev.yml || echo "OK: no prod domains in dev.yml"
grep -E '\.zeaz\.dev' infra/cloudflare/environments/staging.yml || echo "OK: no prod domains in staging.yml"

# Secret check
grep -RInE '(token|secret|password|credential|api[_-]?key)' \
  infra/cloudflare/environments/ \
  docs/infra/cloudflare-environment-boundaries.md || echo "No secrets found"

# Commit
git add docs/infra/cloudflare-environment-boundaries.md \
        docs/infra/cloudflare-environment-ownership-matrix.md \
        docs/infra/cloudflare-cross-environment-drift-policy.md \
        docs/infra/cloudflare-environment-promotion-policy.md \
        infra/cloudflare/environments/dev.yml \
        infra/cloudflare/environments/staging.yml \
        infra/cloudflare/environments/prod.yml \
        infra/cloudflare/scripts/scan-cloudflare-environment-boundaries.sh \
        infra/cloudflare/scripts/validate-cloudflare-config.sh \
        infra/cloudflare/README.md
git commit -m "docs(cloudflare): define multi-environment ownership boundaries"

git push origin fix/cloudflare-multi-environment-separation
gh pr create --title "docs(cloudflare): define multi-environment ownership boundaries" \
  --body "Phase 18: Adds multi-environment separation model (dev/staging/prod), ownership matrix, promotion policy, boundary scanner, and environment intent YAMLs. Read-only. No deploy. No secrets."
```

