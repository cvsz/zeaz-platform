## Suggested Commands

```bash
# Create branch
git checkout -b fix/cloudflare-production-readiness-review

# After writing files
cat docs/infra/cloudflare-production-readiness-review.md
cat docs/infra/cloudflare-production-readiness-checklist.md
cat docs/infra/cloudflare-production-go-no-go-template.md
cat docs/infra/cloudflare-rollback-readiness-checklist.md

# Count checklist items
grep -c "PASS\|FAIL\|BLOCKED" docs/infra/cloudflare-production-readiness-checklist.md

# Verify all 14 areas present
for area in "DNS Ownership" "Tunnel Runtime" "Worker Route" "AI Gateway" "KV / D1" "Terraform" "Secret" "CI Enforcement" "Risk Scoring" "Environment Separation" "Disaster Recovery" "Rollback" "Evidence Archive" "Owner Sign"; do
  grep -q "$area" docs/infra/cloudflare-production-readiness-checklist.md && echo "FOUND: $area" || echo "MISSING: $area"
done

# Secret check
grep -RInE '(token|secret|password|credential|api[_-]?key)' \
  docs/infra/cloudflare-production-readiness-review.md \
  docs/infra/cloudflare-production-readiness-checklist.md \
  docs/infra/cloudflare-production-go-no-go-template.md \
  docs/infra/cloudflare-rollback-readiness-checklist.md || echo "No secrets found"

# Commit
git add docs/infra/cloudflare-production-readiness-review.md \
        docs/infra/cloudflare-production-readiness-checklist.md \
        docs/infra/cloudflare-production-go-no-go-template.md \
        docs/infra/cloudflare-rollback-readiness-checklist.md \
        docs/infra/cloudflare-drift-report.md \
        infra/cloudflare/README.md
git commit -m "docs(cloudflare): add production readiness review"

git push origin fix/cloudflare-production-readiness-review
gh pr create --title "docs(cloudflare): add production readiness review" \
  --body "Phase 20: Adds production readiness checklist (14 areas), go/no-go template, rollback readiness checklist, and readiness review overview. Read-only governance. No deploy. No secrets."
```

