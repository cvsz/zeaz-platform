## Suggested Commands

```bash
# Create branch
git checkout -b fix/cloudflare-post-release-verification

# After writing files
cat docs/infra/cloudflare-post-release-verification.md
cat docs/infra/cloudflare-post-change-evidence-template.md
cat docs/infra/cloudflare-manual-verification-gates.md
cat docs/infra/cloudflare-release-followup-checklist.md

# Verify all 9 gates documented
GATES=("DNS resolution" "Tunnel route" "Worker route" "Access policy" "route overlap" "secret exposure" "Rollback" "Evidence archived" "Owner sign-off")
for gate in "${GATES[@]}"; do
  grep -iq "$gate" docs/infra/cloudflare-manual-verification-gates.md && echo "FOUND: $gate" || echo "MISSING: $gate"
done

# Verify MANUAL/READ-ONLY labels
grep -c "\[MANUAL\]\|\[READ-ONLY\]" docs/infra/cloudflare-manual-verification-gates.md

# Secret check
grep -RInE '(token|secret|password|credential|api[_-]?key)' \
  docs/infra/cloudflare-post-release-verification.md \
  docs/infra/cloudflare-post-change-evidence-template.md \
  docs/infra/cloudflare-manual-verification-gates.md \
  docs/infra/cloudflare-release-followup-checklist.md || echo "No secrets found"

# Commit
git add docs/infra/cloudflare-post-release-verification.md \
        docs/infra/cloudflare-post-change-evidence-template.md \
        docs/infra/cloudflare-manual-verification-gates.md \
        docs/infra/cloudflare-release-followup-checklist.md \
        infra/cloudflare/README.md
git commit -m "docs(cloudflare): add post-release verification gates"

git push origin fix/cloudflare-post-release-verification
gh pr create --title "docs(cloudflare): add post-release verification gates" \
  --body "Phase 21: Adds post-release verification framework with 9 manual gates, evidence template aligned with Phase 16 archive, release follow-up checklist. Read-only governance. No deploy. No secrets."
```

