# Cloudflare platform environment template
#
# Copy to .env.cloudflare, fill real values, and keep .env.cloudflare out of Git.
# Do not commit real tokens, account IDs, or zone IDs to version control.

# Domain and plan
PRIMARY_DOMAIN=zeaz.dev
CLOUDFLARE_PLAN_TIER=Free

# Cost and feature safety guards
COST_LOCK=true
ALLOW_PAID_CLOUDFLARE_FEATURES=false
ALLOW_R2_WRITE=false
ALLOW_WORKERS_DEPLOY=false
ALLOW_LOAD_BALANCING=false
ALLOW_ADVANCED_WAF=false
ALLOW_LOGPUSH=false

# Runtime environment
ENVIRONMENT=dev
REGION=ap-southeast-1
ORIGIN_INFRA_TYPE=vm
ORIGIN_HOSTS=app.internal,pay.internal

# Terraform/OpenTofu backend
TERRAFORM_BACKEND_TYPE=local
TERRAFORM_STATE_BUCKET=
TERRAFORM_LOCK_TABLE=
SECRET_ROTATION_INTERVAL=30d

# Cloudflare account / zone IDs. Fill real values from Cloudflare Dashboard.
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare tokens. Fill real scoped API tokens. Do not use Global API Key.
CLOUDFLARE_API_TOKEN=

# zDash Terraform local variables
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_NAME=zeaz-platform
TF_VAR_cloudflare_zone_id=
TF_VAR_cloudflare_tunnel_id=
TF_VAR_zdash_domain=zdash.zeaz.dev
TF_VAR_zdash_api_domain=api-zdash.zeaz.dev
TF_VAR_zdash_release_domain=release.zeaz.dev

CLOUDFLARE_AI_GATEWAY_SLUG=zeaz

# Scoped service tokens (one per Cloudflare service)
CLOUDFLARE_DNS_TOKEN=
CLOUDFLARE_ZT_TOKEN=
CLOUDFLARE_WORKERS_TOKEN=
CLOUDFLARE_PAGES_TOKEN=
CLOUDFLARE_WAF_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_R2_TOKEN=
CLOUDFLARE_D1_TOKEN=
