#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
EXTRA_ENV_FILE=""
AUTO_LOAD_ENV=true

HOSTNAME="${ZDASH_HOSTNAME:-zdash.zeaz.dev}"
SERVICE="${ZDASH_SERVICE:-http://127.0.0.1:3006}"
API_BASE="https://api.cloudflare.com/client/v4"
FAILED=0

usage() {
  cat <<USAGE
Usage: zeaz-cloudflare-zdash-route [options]

Upserts the Cloudflare Tunnel public hostname route:
  ${HOSTNAME} -> ${SERVICE}

Options:
  --env-file PATH     Load an additional env file after .env.cloudflare and .env.
  --no-env-file       Do not auto-load repo env files.
  -h, --help          Show this help.

Auto-loaded files when present:
  ${PROJECT_ROOT}/.env.cloudflare
  ${PROJECT_ROOT}/.env

Required values after env loading:
  CLOUDFLARE_API_TOKEN
  CLOUDFLARE_ACCOUNT_ID
  CLOUDFLARE_TUNNEL_ID

Legacy fallback names are also accepted:
  CF_API_TOKEN or CF_BOOTSTRAP_TOKEN -> CLOUDFLARE_API_TOKEN
  CF_ACCOUNT_ID -> CLOUDFLARE_ACCOUNT_ID
  CF_TUNNEL_ID -> CLOUDFLARE_TUNNEL_ID

Without required values, this command prints manual Cloudflare dashboard steps only.
USAGE
}

ok() { echo "[OK] $*"; }
warn() { echo "[WARN] $*"; }
fail() { echo "[FAIL] $*"; FAILED=1; }

remember_explicit_env() {
  EXPLICIT_CLOUDFLARE_API_TOKEN_SET=false
  EXPLICIT_CLOUDFLARE_ACCOUNT_ID_SET=false
  EXPLICIT_CLOUDFLARE_TUNNEL_ID_SET=false
  [[ -n "${CLOUDFLARE_API_TOKEN+x}" ]] && EXPLICIT_CLOUDFLARE_API_TOKEN_SET=true && EXPLICIT_CLOUDFLARE_API_TOKEN="${CLOUDFLARE_API_TOKEN}"
  [[ -n "${CLOUDFLARE_ACCOUNT_ID+x}" ]] && EXPLICIT_CLOUDFLARE_ACCOUNT_ID_SET=true && EXPLICIT_CLOUDFLARE_ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_ID}"
  [[ -n "${CLOUDFLARE_TUNNEL_ID+x}" ]] && EXPLICIT_CLOUDFLARE_TUNNEL_ID_SET=true && EXPLICIT_CLOUDFLARE_TUNNEL_ID="${CLOUDFLARE_TUNNEL_ID}"
}

restore_explicit_env() {
  if [[ "${EXPLICIT_CLOUDFLARE_API_TOKEN_SET}" == "true" ]]; then export CLOUDFLARE_API_TOKEN="${EXPLICIT_CLOUDFLARE_API_TOKEN}"; fi
  if [[ "${EXPLICIT_CLOUDFLARE_ACCOUNT_ID_SET}" == "true" ]]; then export CLOUDFLARE_ACCOUNT_ID="${EXPLICIT_CLOUDFLARE_ACCOUNT_ID}"; fi
  if [[ "${EXPLICIT_CLOUDFLARE_TUNNEL_ID_SET}" == "true" ]]; then export CLOUDFLARE_TUNNEL_ID="${EXPLICIT_CLOUDFLARE_TUNNEL_ID}"; fi
}

load_env_file() {
  local file_path="$1"
  if [[ -f "${file_path}" ]]; then
    # shellcheck disable=SC1090
    set -a
    source "${file_path}"
    set +a
    ok "loaded env file: ${file_path}"
  fi
}

load_env() {
  remember_explicit_env

  if [[ "${AUTO_LOAD_ENV}" == "true" ]]; then
    load_env_file "${PROJECT_ROOT}/.env.cloudflare"
    load_env_file "${PROJECT_ROOT}/.env"
  fi

  if [[ -n "${EXTRA_ENV_FILE}" ]]; then
    load_env_file "${EXTRA_ENV_FILE}"
  fi

  restore_explicit_env

  : "${CLOUDFLARE_API_TOKEN:=${CF_API_TOKEN:-${CF_BOOTSTRAP_TOKEN:-${CF_TUNNEL_TOKEN:-}}}}"
  : "${CLOUDFLARE_ACCOUNT_ID:=${CF_ACCOUNT_ID:-}}"
  : "${CLOUDFLARE_TUNNEL_ID:=${CF_TUNNEL_ID:-}}"
  export CLOUDFLARE_API_TOKEN CLOUDFLARE_ACCOUNT_ID CLOUDFLARE_TUNNEL_ID
}

manual_instructions() {
  local missing_display="$1"
  cat <<MANUAL
[SKIP] Cloudflare API environment is incomplete; no API changes attempted.
[WARN] Missing environment variables: ${missing_display}

Expected env sources:
  - ${PROJECT_ROOT}/.env.cloudflare
  - ${PROJECT_ROOT}/.env
  - --env-file PATH

Manual Cloudflare Zero Trust dashboard steps:
  1. Open Zero Trust dashboard > Networks > Tunnels.
  2. Select the existing production tunnel for zeaz.dev.
  3. Add a Public Hostname without changing existing routes:
     - Subdomain: zdash
     - Domain: zeaz.dev
     - Type: HTTP
     - URL: 127.0.0.1:3006
  4. Save the route and confirm the connector is healthy.
  5. Open https://zdash.zeaz.dev after the dashboard service is running.
MANUAL
}

while (($#)); do
  case "$1" in
    --env-file)
      shift
      EXTRA_ENV_FILE="${1:?missing --env-file value}"
      ;;
    --no-env-file)
      AUTO_LOAD_ENV=false
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
  shift
done

load_env

ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_ID:-}"
TUNNEL_ID="${CLOUDFLARE_TUNNEL_ID:-}"

missing=()
for var_name in CLOUDFLARE_API_TOKEN CLOUDFLARE_ACCOUNT_ID CLOUDFLARE_TUNNEL_ID; do
  if [[ -z "${!var_name:-}" ]]; then
    missing+=("${var_name}")
  fi
done

if [[ "${#missing[@]}" -gt 0 ]]; then
  missing_display="$(IFS=,; printf '%s' "${missing[*]}")"
  manual_instructions "${missing_display}"
  exit 0
fi

command -v curl >/dev/null 2>&1 || { fail "curl not found"; exit 1; }
command -v jq >/dev/null 2>&1 || { fail "jq not found; required to preserve existing tunnel routes safely"; exit 1; }

if [[ ! "${ACCOUNT_ID}" =~ ^[A-Za-z0-9_-]{16,64}$ ]]; then
  fail "CLOUDFLARE_ACCOUNT_ID format is invalid"
  exit 1
fi

if [[ ! "${TUNNEL_ID}" =~ ^[A-Za-z0-9_-]{16,80}$ ]]; then
  fail "CLOUDFLARE_TUNNEL_ID format is invalid"
  exit 1
fi

work_dir="$(mktemp -d)"
chmod 0700 "${work_dir}"
curl_config="${work_dir}/curl.conf"
cat > "${curl_config}" <<CURLCONFIG
header = "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}"
header = "Content-Type: application/json"
CURLCONFIG
chmod 0600 "${curl_config}"
cleanup() { rm -rf "${work_dir}"; }
trap cleanup EXIT
trap 'fail "Cloudflare zdash route update interrupted at line ${LINENO}"; exit 1' ERR

config_url="${API_BASE}/accounts/${ACCOUNT_ID}/cfd_tunnel/${TUNNEL_ID}/configurations"
get_body="${work_dir}/get.json"
put_body="${work_dir}/put.json"
response_body="${work_dir}/response.json"
http_code="$(curl -sS -o "${get_body}" -w '%{http_code}' --config "${curl_config}" "${config_url}")"

if [[ ! "${http_code}" =~ ^2 ]]; then
  fail "Cloudflare API read failed with HTTP ${http_code}"
  exit 1
fi

if ! jq -e '.success == true' "${get_body}" >/dev/null; then
  fail "Cloudflare API read response was not successful"
  exit 1
fi

jq --arg hostname "${HOSTNAME}" --arg service "${SERVICE}" '
  def is_catchall: ((has("hostname") | not) or (.hostname == null));
  (.result.config // {}) as $cfg
  | ($cfg.ingress // []) as $ingress
  | ($ingress | map(select((is_catchall | not) and (.hostname != $hostname)))) as $preserved
  | ($ingress | map(select(is_catchall))) as $catchall
  | {
      config: ($cfg + {
        ingress: ($preserved + [{hostname: $hostname, service: $service}] + $catchall)
      })
    }
' "${get_body}" > "${put_body}"

if ! jq -e --arg hostname "${HOSTNAME}" --arg service "${SERVICE}" '
  [.config.ingress[] | select(.hostname == $hostname and .service == $service)] | length == 1
' "${put_body}" >/dev/null; then
  fail "generated route payload did not contain exactly one ${HOSTNAME} route"
  exit 1
fi

http_code="$(curl -sS -o "${response_body}" -w '%{http_code}' -X PUT --config "${curl_config}" --data-binary "@${put_body}" "${config_url}")"

if [[ ! "${http_code}" =~ ^2 ]]; then
  fail "Cloudflare API update failed with HTTP ${http_code}"
  exit 1
fi

if jq -e '.success == true' "${response_body}" >/dev/null; then
  ok "upserted ${HOSTNAME} -> ${SERVICE} without removing existing tunnel routes"
else
  fail "Cloudflare API update response was not successful"
  exit 1
fi

exit "${FAILED}"
