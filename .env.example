# zeaz-platform environment template
#
# Copy to .env, fill real values locally, and keep .env out of Git.
# Canonical Cloudflare variable names use the CLOUDFLARE_* prefix for IDs and scoped service tokens.

# Cloudflare account / zone
CLOUDFLARE_ACCOUNT_ID=y
CLOUDFLARE_ZONE_ID=
PRIMARY_DOMAIN=zeaz.dev
CLOUDFLARE_PLAN_TIER=Free

# Bootstrap token for token lifecycle operations.
# Must be a scoped account-owned token with token-management permissions.
# Do not use or commit a Global API Key.
CLOUDFLARE_BOOTSTRAP_TOKEN=

# General Cloudflare API token used by Terraform/OpenTofu when a more specific token is not supplied.
CLOUDFLARE_API_TOKEN=

# Scoped service tokens
CLOUDFLARE_DNS_TOKEN=
CLOUDFLARE_ZT_TOKEN=
CLOUDFLARE_WORKERS_TOKEN=
CLOUDFLARE_WAF_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_R2_TOKEN=
CLOUDFLARE_AUDIT_TOKEN=
CLOUDFLARE_AI_GATEWAY_TOKEN=
CLOUDFLARE_AI_GATEWAY_SLUG=zeaz

# Free/no-cost safety guardrails
COST_LOCK=true
ALLOW_PAID_CLOUDFLARE_FEATURES=false
ALLOW_R2_WRITE=false
ALLOW_WORKERS_DEPLOY=false
ALLOW_LOAD_BALANCING=false
ALLOW_ADVANCED_WAF=false
ALLOW_LOGPUSH=false

# Identity provider metadata for Zero Trust Access
IDENTITY_PROVIDER_TYPE=saml
IDENTITY_PROVIDER_VENDOR=
IDENTITY_PROVIDER_METADATA_URL=

# Runtime environment
ENVIRONMENT=dev
REGION=ap-southeast-1
ORIGIN_INFRA_TYPE=vm
ORIGIN_HOSTS=app.internal,pay.internal

# Terraform/OpenTofu backend
# Use local for FREE NO COST mode. Only set s3 values when explicitly using an AWS backend.
TERRAFORM_BACKEND_TYPE=local
TERRAFORM_STATE_BUCKET=
TERRAFORM_LOCK_TABLE=

# Secrets management
SOPS_AGE_KEY=
SECRET_ROTATION_INTERVAL=30d
