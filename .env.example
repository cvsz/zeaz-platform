# zeaz-platform environment template
#
# Copy to .env, fill real values locally, and keep .env out of Git.
# Canonical Cloudflare variable names use the CLOUDFLARE_* prefix for IDs and scoped service tokens.

# Cloudflare account / zone
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
PRIMARY_DOMAIN=zeaz.dev
CLOUDFLARE_PLAN_TIER=Free

# Bootstrap token for token lifecycle operations.
# Must be a scoped account-owned token with token-management permissions.
# Do not use or commit a Global API Key.
CLOUDFLARE_BOOTSTRAP_TOKEN=

# General Cloudflare API token used by Terraform/OpenTofu when a more specific token is not supplied.
CLOUDFLARE_API_TOKEN=

# Scoped service tokens generated by make token-rotate.
CLOUDFLARE_DNS_TOKEN=
CLOUDFLARE_ZT_TOKEN=
CLOUDFLARE_WORKERS_TOKEN=
CLOUDFLARE_WAF_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_R2_TOKEN=

# Optional tokens. Add these only when real values exist; do not keep empty assignments.
# CLOUDFLARE_AUDIT_TOKEN=<real-token>
# CLOUDFLARE_AI_GATEWAY_TOKEN=<real-token>
CLOUDFLARE_AI_GATEWAY_SLUG=zeaz

# Free/no-cost safety guardrails
COST_LOCK=true
ALLOW_PAID_CLOUDFLARE_FEATURES=false
ALLOW_R2_WRITE=false
ALLOW_WORKERS_DEPLOY=false
ALLOW_LOAD_BALANCING=false
ALLOW_ADVANCED_WAF=false
ALLOW_LOGPUSH=false

# Identity provider metadata for Zero Trust Access
IDENTITY_PROVIDER_TYPE=saml
IDENTITY_PROVIDER_VENDOR=
IDENTITY_PROVIDER_METADATA_URL=

# Runtime environment
ENVIRONMENT=dev
REGION=ap-southeast-1
ORIGIN_INFRA_TYPE=vm
ORIGIN_HOSTS=web.internal,app.internal,pay.internal

# Terraform/OpenTofu backend
# Use local for FREE NO COST mode. Only set s3 values when explicitly using an AWS backend.
TERRAFORM_BACKEND_TYPE=local
TERRAFORM_STATE_BUCKET=
TERRAFORM_LOCK_TABLE=

# Secrets management
# Age private keys are local-only. Set them in .env when needed; do not keep them in tracked templates.
SECRET_ROTATION_INTERVAL=30d

# Postgres / Vector DB
DB_USER=example-ai-user
DB_PASS=
DB_NAME=example_ai_runtime

# Minio S3
MINIO_ROOT_USER=example-admin
MINIO_ROOT_PASSWORD=

# Authentik
PG_USER=example-authentik
PG_PASS=
PG_DB=example_authentik
AUTHENTIK_SECRET_KEY=

# Grafana
GRAFANA_PASSWORD=

# AI Integrations
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_ACCOUNT_ID=


# Canonical ZEAZ app runtime
NODE_ENV=development
APP_NAME=zeaz-platform
APP_DOMAIN=zeaz.dev
APP_BASE_URL=https://zeaz.dev
API_BASE_URL=https://api-zcfdash.zeaz.dev
PORT=4103

# Canonical PostgreSQL / Redis runtime
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zeaz_platform
POSTGRES_USER=zeazdev
POSTGRES_PASSWORD=
DATABASE_URL=
REDIS_URL=redis://redis:6379/0

# Cloudflare tunnel metadata (local/CI secret values only)
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_NAME=zeaz-platform
CLOUDFLARE_TUNNEL_CREDENTIALS_FILE=

# Supabase AI tools / MCP integration
# Keep SUPABASE_ACCESS_TOKEN local-only in .env or CI secrets; do not commit real tokens.
SUPABASE_PROJECT_REF=
SUPABASE_MCP_BASE_URL=https://mcp.supabase.com/mcp
SUPABASE_MCP_CONFIG_OUT=.agent/supabase-mcp.json
SUPABASE_DOCS_CACHE_DIR=.cache/supabase-ai-tools
