# ZEAZ Platform environment template
# Copy to .env and fill real values locally. Keep .env and generated secrets out of Git.
# Example values in this file are non-production placeholders only.

NODE_ENV=development
ENVIRONMENT=local
REGION=us-east-1
PRIMARY_DOMAIN=zeaz.dev
CLOUDFLARE_PLAN_TIER=free

# Database Configuration
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=zeaz
POSTGRES_USER=zeaz_admin
POSTGRES_PASSWORD=example-postgres-password
DATABASE_URL=postgresql://zeaz_admin:example-postgres-password@127.0.0.1:5432/zeaz
REDIS_URL=redis://127.0.0.1:6379/0

# App Ports Matrix
OPENWORK_PORT=4101
API_PORT=4102
WEB_PORT=4103
ZOFFICE_PORT=4104
ZWALLET_PORT=4105
ZTRADER_PORT=4106
ZDASH_PORT=4107
ZSP_AITOOL_PORT=4108
ZVEO_PORT=4109
ZSTICKER_PORT=4110
ZCINO_PORT=4111
ZLMS_PROD_PORT=4112
ZLINEBOT_PORT=4113

# Cloudflare account, zone, tunnel, and scoped tokens.
# Keep real values in .env or CI secrets. Do not use a global Cloudflare API key.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_NAME=zeaz-platform
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DNS_TOKEN=
CLOUDFLARE_ZT_TOKEN=
CLOUDFLARE_WORKERS_TOKEN=
CLOUDFLARE_WAF_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_R2_TOKEN=
CLOUDFLARE_AI_GATEWAY_SLUG=zeaz

# Cost and No-Cost Guardrails
COST_LOCK=true
ALLOW_PAID_CLOUDFLARE_FEATURES=false
ALLOW_R2_WRITE=false
ALLOW_WORKERS_DEPLOY=false
ALLOW_LOAD_BALANCING=false
ALLOW_ADVANCED_WAF=false
ALLOW_LOGPUSH=false

# Identity and platform controls
IDENTITY_PROVIDER_TYPE=saml
IDENTITY_PROVIDER_VENDOR=
IDENTITY_PROVIDER_METADATA_URL=
ORIGIN_INFRA_TYPE=local
ORIGIN_HOSTS=localhost
TERRAFORM_BACKEND_TYPE=local
TERRAFORM_STATE_BUCKET=
TERRAFORM_LOCK_TABLE=
SECRET_ROTATION_INTERVAL=30d

# zLinebot secrets: set real values only in local .env or CI secret stores.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_SECRET=

# Optional provider secrets: set real values only in local .env or CI secret stores.
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_ACCOUNT_ID=

# Supabase MCP placeholders
SUPABASE_PROJECT_REF=
SUPABASE_MCP_URL=
SUPABASE_MCP_ANON_KEY=
SUPABASE_MCP_BASE_URL=https://mcp.supabase.com/mcp
SUPABASE_MCP_CONFIG_OUT=.agent/supabase-mcp.json
SUPABASE_DOCS_CACHE_DIR=.cache/supabase-ai-tools
