# --- Cloudflare Credentials ---
CLOUDFLARE_ACCOUNT_ID=example-account-id
CLOUDFLARE_ZONE_ID=example-zone-id
CLOUDFLARE_API_TOKEN=example-api-token
CLOUDFLARE_DNS_TOKEN=example-dns-token
CLOUDFLARE_WORKERS_TOKEN=example-workers-token
CLOUDFLARE_ZT_TOKEN=example-zt-token
CLOUDFLARE_WAF_TOKEN=example-waf-token
CLOUDFLARE_TUNNEL_TOKEN=example-tunnel-token
CLOUDFLARE_R2_TOKEN=example-r2-token
CLOUDFLARE_AI_GATEWAY_SLUG=example-gateway-slug

# --- Identity Provider ---
IDENTITY_PROVIDER_TYPE=saml
IDENTITY_PROVIDER_VENDOR=okta
IDENTITY_PROVIDER_METADATA_URL=https://example.com/saml/metadata

# --- Environment ---
ENVIRONMENT=dev
REGION=us-east-1
PRIMARY_DOMAIN=zeaz.dev

# --- Terraform/OpenTofu ---
TERRAFORM_BACKEND_TYPE=s3
TERRAFORM_STATE_BUCKET=zeaz-platform-state
TERRAFORM_LOCK_TABLE=zeaz-platform-lock

# --- Security ---
SOPS_AGE_KEY=age1example...
SECRET_ROTATION_INTERVAL=90d

# --- Terraform/OpenTofu Vars ---
TF_VAR_account_id=example-account-id
TF_VAR_zone_id=example-zone-id
TF_VAR_tunnel_secret=example-tunnel-secret
TF_VAR_cloudflare_bootstrap_token=example-bootstrap-token
TF_VAR_enable_waf=false

# Google Drive Storage Integration (zfbauto)
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
