{
  "version": 1,
  "default_profile": "openrouter-qwen-coder",
  "profiles": [
    {
      "id": "openrouter-qwen-coder",
      "provider": "openrouter",
      "model": "qwen/qwen3-coder",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "context_window": 262144,
      "max_output_tokens": 8192,
      "temperature": 0.2,
      "supports_tool_calling": true,
      "supports_vision": false,
      "supports_json_mode": true,
      "recommended_for": ["coding", "repo edits", "refactor", "tests"]
    },
    {
      "id": "openrouter-deepseek",
      "provider": "openrouter",
      "model": "deepseek/deepseek-chat",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "context_window": 128000,
      "max_output_tokens": 8192,
      "temperature": 0.2,
      "supports_tool_calling": true,
      "supports_vision": false,
      "supports_json_mode": true,
      "recommended_for": ["architecture", "debugging", "large repo reasoning"]
    },
    {
      "id": "ollama-qwen-local",
      "provider": "ollama",
      "model": "qwen2.5-coder:14b",
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key_env": "OLLAMA_API_KEY",
      "context_window": 32768,
      "max_output_tokens": 4096,
      "temperature": 0.2,
      "supports_tool_calling": false,
      "supports_vision": false,
      "supports_json_mode": false,
      "recommended_for": ["local coding", "offline review", "safe-cost"]
    },
    {
      "id": "lmstudio-local",
      "provider": "openai-compatible",
      "model": "local-model",
      "base_url": "http://127.0.0.1:1234/v1",
      "api_key_env": "LMSTUDIO_API_KEY",
      "context_window": 32768,
      "max_output_tokens": 4096,
      "temperature": 0.2,
      "supports_tool_calling": false,
      "supports_vision": false,
      "supports_json_mode": false,
      "recommended_for": ["local experiments", "no-cost"]
    }
  ],
  "routes": {
    "architect": "openrouter-deepseek",
    "coder": "openrouter-qwen-coder",
    "reviewer": "openrouter-qwen-coder",
    "local": "ollama-qwen-local",
    "offline": "lmstudio-local"
  }
}
