name = "edge-gateway"
main = "src/index.ts"
compatibility_date = "2026-05-12"
workers_dev = true

[[kv_namespaces]]
binding = "EDGE_RATE_LIMIT_KV"
id = "00000000000000000000000000000000"

# Optional: enable Durable Object limiter for strong consistency on high-risk endpoints.
# [durable_objects]
# bindings = [{ name = "EDGE_DURABLE_LIMITER", class_name = "EdgeDurableLimiter" }]

[vars]
JWT_AUDIENCE = "edge-gateway"
EDGE_USE_DURABLE_LIMITER = "false"
CF_AI_GATEWAY_SLUG = "cloudflare-platform-ai-gateway"
# JWT_SECRET must be injected with `wrangler secret put JWT_SECRET` or GitHub Actions secret.
