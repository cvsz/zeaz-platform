{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "node"],
    "outDir": "dist"
  },
  "include": [
    "shared/**/*.ts",
    "edge-gateway/src/**/*.ts",
    "../tests/workers/**/*.ts"
  ]
}
