# OpenWork — runtime env (mode=electron shown; trim to your mode)
#
# Location: ~/.config/openwork/openwork.env  (chmod 600)
# Re-read after edits:  systemctl --user daemon-reload && systemctl --user restart openwork.service

# ---- Mode ----------------------------------------------------------------
# electron | ui | web | den
OPENWORK_MODE=electron

# ---- Dev toggles ---------------------------------------------------------
OPENWORK_DEV_MODE=1
# OPENWORK_ELECTRON_REMOTE_DEBUG_PORT=9823

# ---- Graphical session (electron mode only) ------------------------------
# For a real desktop session; X11 / Wayland both work.
DISPLAY=:0
# WAYLAND_DISPLAY=wayland-0
# XDG_SESSION_TYPE=wayland

# ---- Ports (headless web / den modes) ------------------------------------
# DEN_API_PORT=8790
# DEN_WEB_PORT=3005
# OPENWORK_APP_PORT=5173
# INFERENCE_PORT=8791

# ---- Den secrets (den mode only) -----------------------------------------
# Generate per-run: openssl rand -base64 48
# BETTER_AUTH_SECRET=
# DEN_DB_ENCRYPTION_KEY=
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/openwork_den

# ---- Optional provider keys ----------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
