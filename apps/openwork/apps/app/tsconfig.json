{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"]
  },
  "include": [
    "globals.d.ts",
    "src/index.react.tsx",
    "src/components/**/*",
    "src/i18n/**/*",
    "src/lib/**/*",
    "src/overlay/**/*",
    "src/react-app/**/*",
    "src/app/lib/**/*",
    "src/app/cloud/**/*",
    "src/app/data/**/*",
    "src/app/utils/**/*",
    "src/app/constants.ts",
    "src/app/types.ts",
    "src/app/theme.ts",
    "src/app/mcp.ts",
    "vite.config.ts"
  ]
}
