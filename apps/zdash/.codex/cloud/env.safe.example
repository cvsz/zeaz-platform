# zDash Codex Cloud safe defaults (non-secret)
# Keep real secrets outside git (Codex Cloud environment settings / secret manager).

APP_ENV=development
LOG_LEVEL=INFO
BACKEND_PORT=8005

# Core platform safety
PRODUCTION_SAFETY_LOCK=true
PRODUCTION_ALLOW_LIVE_ACTIONS=false
AUTH_ENABLED=false
AUTH_ALLOW_BOOTSTRAP_IN_PRODUCTION=false
METRICS_AUTH_REQUIRED=false
METRICS_ALLOW_UNAUTHENTICATED_DEV=true

# Trading safety
DRY_RUN=true
LIVE_TRADING_ACK=false
RISK_GUARDIAN_ENABLED=true
MT5_ENABLED=false
ALLOW_STRATEGY_PROMOTION=false

# Content safety
SOCIAL_DRY_RUN=true
SOCIAL_APPROVAL_REQUIRED=true
SOCIAL_AUTO_POST_ENABLED=false
SOCIAL_REAL_POSTING_APPROVED=false

# IoT safety
IOT_DRY_RUN=true
IOT_REQUIRE_CONFIRMATION=true
IOT_REAL_ACTIONS_APPROVED=false

# Deployment/support safety
DEPLOYMENT_PACK_DRY_RUN=true
DEPLOYMENT_PACK_INCLUDE_SECRETS=false
SUPPORT_BUNDLE_DRY_RUN=true
SUPPORT_BUNDLE_INCLUDE_SECRETS=false

# Update safety
UPDATE_DRY_RUN=true
UPDATE_AUTO_APPLY=false
UPDATE_ROLLBACK_DRY_RUN=true

# Security/data safety
RAG_REDACTION_STRICT=true
RAG_ALLOW_SECRET_RETRIEVAL=false
SECURITY_ACTIVE_SCANNING=false
DLP_STRICT=true

# Non-secret placeholders
DATABASE_URL=sqlite:///./zdash.db
JWT_SECRET_KEY=dev-only-change-before-production
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=dev-only-change-before-production
DEFAULT_ADMIN_PASSWORD=dev-only-change-before-production

# Provider placeholders
CLAUDE_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
CLOUDFLARE_API_TOKEN=
