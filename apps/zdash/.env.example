AI_TRADING_PROVIDER=mock
AI_PROVIDER=mock
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# Phase 03 risk system defaults (fail-closed, dry-run first)
RISK_GUARDIAN_ENABLED=true
MAX_DAILY_DRAWDOWN_PERCENT=5
MAX_TOTAL_DRAWDOWN_PERCENT=20
EMERGENCY_KILL_SWITCH_DRAWDOWN_PERCENT=50
SOFT_HALT_DRAWDOWN_LEVEL_1=5
SOFT_HALT_DRAWDOWN_LEVEL_2=10
SOFT_HALT_DRAWDOWN_LEVEL_3=20
ALLOW_MANUAL_RESUME=true
REQUIRE_RESUME_REASON=true
HARD_HALT_ON_DAILY_DRAWDOWN=false

# Phase 04 automation defaults (scheduler + IoT dry-run)
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Bangkok
SCHEDULER_DEFAULT_MAX_RUNTIME_SECONDS=300
SCHEDULER_ALLOW_MANUAL_RUN=true
SCHEDULER_STORE=in_memory
FRIDAY_AGENT_ENABLED=true

IOT_ENABLED=true
