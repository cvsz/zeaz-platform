APP_NAME=zDash
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8005
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
DATABASE_URL=sqlite:///./zdash.db
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
PRODUCTION_SAFETY_LOCK=true
PRODUCTION_ALLOW_LIVE_ACTIONS=false
AUTH_ENABLED=false
AUTH_ALLOW_BOOTSTRAP_IN_PRODUCTION=false
METRICS_AUTH_REQUIRED=false
METRICS_ALLOW_UNAUTHENTICATED_DEV=true
JWT_SECRET_KEY=dev-only-change-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=dev-only-change-before-production
DEFAULT_ADMIN_PASSWORD=dev-only-change-before-production

# Phase 02 trading core defaults (simulation only)
TRADING_ENABLED=true
DRY_RUN=true
LIVE_TRADING_ACK=false
MT5_ENABLED=false
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
