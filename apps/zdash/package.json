{
  "name": "zdash",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "zDash AI Agent System dashboard built with React and Vite for local zdash.zeaz.dev and Cloudflare deployment.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3006 --strictPort",
    "dev:lan": "vite --host 0.0.0.0 --port 3006 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 3006 --strictPort",
    "preview:lan": "vite preview --host 0.0.0.0 --port 3006 --strictPort",
    "start:local": "npm run build && npm run preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0"
  }
}
