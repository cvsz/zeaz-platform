cd backend
uvicorn app.main:app --reload

Run web frontend:

cd frontend
npm run dev

Run mobile app:

cd mobile
npm install
npx expo start

Create API key:

curl -X POST http://localhost:8000/api/developer/api-keys \
  -H "Authorization: Bearer TOKEN" \
  -H "Content-Type: application/json" \
  -d '{
    "name": "Sandbox Dev Key",
    "scopes": ["sandbox:all", "read:risk", "read:backtesting", "write:backtesting"],
    "sandbox_only": true
  }'

Partner API health:

curl http://localhost:8000/partner/v1/health \
  -H "X-ZDash-API-Key: RAW_API_KEY"

Partner risk status:

curl http://localhost:8000/partner/v1/risk/status \
  -H "X-ZDash-API-Key: RAW_API_KEY"

