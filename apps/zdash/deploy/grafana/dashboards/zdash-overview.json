    },
    {
      "type": "timeseries",
      "title": "Trading Scans",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "sum(rate(zdash_trading_scan_total[5m]))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Risk Halts",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "sum(rate(zdash_risk_halt_total[5m]))", "refId": "A"}]
