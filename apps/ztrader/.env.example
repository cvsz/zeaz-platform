# ztrader Platform Configuration Example
# Copy this file to .env and configure appropriate values before running.

# System Environment
ENVIRONMENT=test-environment
PORT=8000
HOST=0.0.0.0

# Database & Cache URLs
DATABASE_URL=postgresql+asyncpg://ztrader:example-db-password@localhost:5432/ztrader_db
REDIS_URL=redis://localhost:6379/0

# Security (Replace with real 32-byte keys/secrets in production .env)
# Do NOT check real keys into version control.
ENCRYPTION_KEY=00000000000000000000000000000000
JWT_SECRET=00000000000000000000000000000000
ADMIN_API_TOKEN=example-admin-api-token

# Trading Defaults
EXECUTION_MODE=paper # paper or live
LIVE_TRADING_ENABLED=false
GLOBAL_KILL_SWITCH=false

# Risk Limits
RISK_MAX_ORDER_NOTIONAL=100.0
RISK_ALLOWED_SYMBOLS=BTC/USDT,ETH/USDT

# Google OAuth 2.0 Credentials (Placeholder)
GOOGLE_CLIENT_ID=example-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-google-client-secret

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
