# ztrader Platform Configuration Example
# Copy this file to .env and configure appropriate values before running.
# Never commit real .env files or production secrets.

# System Environment
ENVIRONMENT=production
HOST=127.0.0.1
BACKEND_PORT=8016
FRONTEND_PORT=3016
PORT=8016

# Public route mapping
ZTRADER_PUBLIC_URL=https://ztrader.zeaz.dev
NEXT_PUBLIC_BACKEND_URL=https://api-ztrader.zeaz.dev
NEXT_PUBLIC_API_BASE_URL=https://api-ztrader.zeaz.dev/api/v1

# Database & Cache URLs
DATABASE_URL=postgresql+asyncpg://ztrader:example-db-password@localhost:5432/ztrader_db
REDIS_URL=redis://localhost:6379/0

# Security placeholders only. Generate real values locally and keep them outside git.
ENCRYPTION_KEY=example-32-byte-secret
JWT_SECRET=example-jwt-secret
ADMIN_API_TOKEN=example-admin-token
TRADINGVIEW_WEBHOOK_SECRET=example-webhook-secret

# Trading Defaults
EXECUTION_MODE=paper
LIVE_TRADING_ENABLED=false
GLOBAL_KILL_SWITCH=true

# Risk Limits
RISK_MAX_ORDER_NOTIONAL=100.0
RISK_ALLOWED_SYMBOLS='["BTC/USDT","ETH/USDT"]'

# Google OAuth 2.0 Credentials placeholders
GOOGLE_CLIENT_ID=example-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-google-client-secret
