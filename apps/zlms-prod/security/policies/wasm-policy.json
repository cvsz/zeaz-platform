{
  "schemaVersion": 1,
  "policyId": "zlms-zero-trust-wasm-runtime",
  "enforcement": "deny-by-default",
  "runtime": {
    "primaryEngine": "wasmtime",
    "browserFallback": "webassembly-wasi-preview1",
    "wasiPreview": "wasi_snapshot_preview1",
    "allowUnsignedModules": false,
    "requireModuleSignature": true,
    "requireSRI": true,
    "requireImmutableUrlHash": true,
    "requireRuntimeAttestation": true
  },
  "sandbox": {
    "filesystem": "denied",
    "network": "denied-by-default",
    "environment": "explicit-allowlist-only",
    "stdin": "denied",
    "stdout": "structured-captured-log-only",
    "maxMemoryBytes": 67108864,
    "maxExecutionMilliseconds": 1000,
    "maxModuleBytes": 10485760
  },
  "signing": {
    "acceptedAlgorithms": ["ECDSA-P256-SHA256"],
    "keyRotationDays": 90,
    "revocationListRequired": true
  },
  "attestation": {
    "evidence": [
      "moduleId",
      "moduleDigest",
      "signatureKeyId",
      "wasiCapabilities",
      "memoryLimitBytes",
      "executionTimeoutMilliseconds",
      "engine"
    ],
    "retentionDays": 365
  },
  "containment": {
    "onSignatureFailure": "kill-remote",
    "onIntegrityFailure": "kill-remote",
    "onTimeout": "open-circuit-breaker",
    "onCapabilityViolation": "quarantine-remote"
  }
}
