<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appSettings>
    <add key="LoginRateLimitMaxAttempts" value="5" />
    <add key="LoginRateLimitWindowMinutes" value="15" />
    <add key="SmtpFromAddress" value="no-reply@localhost" />
  </appSettings>
  <system.diagnostics>
    <sources>
      <source name="zlms.security" switchValue="Information">
        <listeners>
          <add name="securityTrace" />
          <remove name="Default" />
        </listeners>
      </source>
    </sources>
    <sharedListeners>
      <add name="securityTrace" type="System.Diagnostics.TextWriterTraceListener" initializeData="App_Data\security.log" />
    </sharedListeners>
  </system.diagnostics>
  <system.web>
    <compilation debug="false" targetFramework="4.6.1" />
    <httpRuntime targetFramework="4.6.1" maxRequestLength="51200" requestValidationMode="4.5" enableVersionHeader="false" executionTimeout="110" />
    <customErrors defaultRedirect="UpdatingSystem.aspx" mode="On">
      <error statusCode="500" redirect="UpdatingSystem.aspx" />
    </customErrors>
    <pages controlRenderingCompatibilityVersion="4.0" validateRequest="true" viewStateEncryptionMode="Always" enableViewStateMac="true" />
    <httpCookies httpOnlyCookies="true" requireSSL="true" sameSite="Strict" />
    <sessionState timeout="30" cookieSameSite="Strict" />
  </system.web>
  <connectionStrings>
    <add name="cdas_conn" connectionString="Data Source=POLOCEDBC-LMS\SQLEXPRESS;Initial Catalog=POLICE_LMS;Integrated Security=True;Encrypt=True;TrustServerCertificate=False" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <system.codedom>
    <compilers />
  </system.codedom>
  <system.webServer>
    <security>
      <requestFiltering removeServerHeader="true">
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="no-referrer" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=()" />
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'" />
      </customHeaders>
    </httpProtocol>
    <httpErrors>
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" prefixLanguageFilePath="" path="/assets/images/blank.png" responseMode="Redirect" />
    </httpErrors>
  </system.webServer>
  <runtime />
</configuration>
