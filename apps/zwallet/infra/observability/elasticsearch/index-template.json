{
  "index_patterns": ["logs-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": {"type": "date"},
        "event": {"type": "keyword"},
        "identity": {"type": "keyword"},
        "risk_score": {"type": "integer"},
        "message": {"type": "text"}
      }
    }
  }
}