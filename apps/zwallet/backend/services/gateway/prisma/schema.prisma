generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  boundAt   DateTime @default(now())
  @@unique([userId, deviceId])
}

model WalletMetadata {
  id          String   @id @default(uuid())
  userId      String
  walletLabel String
  network     String
  address     String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  payload   Json
  createdAt DateTime @default(now())
}
