generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WalletBalance {
  id        String   @id @default(uuid())
  userId    String   @unique
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  type      String   // 'ADD' or 'DEDUCT'
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
}
