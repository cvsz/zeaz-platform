# zWallet Environment Variables Example

# --- API Configuration ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- Event Bus Configuration ---
# Options: 'memory' | 'redis' | 'nats' | 'kafka'
EVENT_BUS_TYPE=memory
EVENT_BUS_URL=redis://localhost:6379

# --- Database Configuration ---
# DATABASE_URL="postgresql://user:password@localhost:5432/zwallet?schema=public"

# --- Blockchain Configuration ---
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Security Configuration ---
# JWT_SECRET=your-super-secret-jwt-key
# ENCRYPTION_KEY=your-32-byte-base64-encryption-key (for AES-256-GCM)

# --- Service Specific ---
# COMPLIANCE_API_URL=http://compliance:3001
# RISK_ENGINE_URL=http://risk-engine:3002

# --- Stripe Integration ---
# STRIPE_SECRET_KEY=
# STRIPE_ACCOUNT_ID=
# STRIPE_TREASURY_ENABLED=true
