{
  "name": "zwallet",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "check:circular": "madge --circular --extensions ts apps/zeaz-api/src services/wallet-engine/src services/swap-engine/src services/indexer/src packages/crypto-core/src packages/chain-adapters/src packages/shared-types/src",
    "setup:auto": "node scripts/run-installer.mjs",
    "generate:releases": "node scripts/generate-releases.mjs",
    "build": "exit 0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.26.0",
    "madge": "^8.0.0",
    "typescript": "^5.8.3"
  }
}