@import "tailwindcss";

:root {
  --background: #09090b;
  --foreground: #f4f4f5;
  --font-sans: var(--font-inter), sans-serif;
  --font-heading: var(--font-outfit), sans-serif;
}

body {
  background: #09090b;
  color: #f4f4f5;
  font-family: var(--font-sans);
}

@theme {
  --font-sans: var(--font-inter), sans-serif;
  --font-heading: var(--font-outfit), sans-serif;
}

/* Custom scrollbars */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: #09090b;
}
::-webkit-scrollbar-thumb {
  background: #27272a;
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: #3f3f46;
}

/* Smooth fade-in animation utilities */
.animate-fade-in {
  animation: fadeIn 0.25s ease-out forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(4px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Premium Tech Visual Extensions */

.bg-cyber-grid {
  background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.02) 1px, transparent 0);
  background-size: 24px 24px;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-slide-up {
  animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes pulse-glow {
  0%, 100% {
    opacity: 0.15;
    transform: scale(1) translate(0, 0);
  }
  50% {
    opacity: 0.25;
    transform: scale(1.1) translate(10px, -10px);
  }
}

.animate-pulse-glow-1 {
  animation: pulse-glow 15s ease-in-out infinite;
}

.animate-pulse-glow-2 {
  animation: pulse-glow 20s ease-in-out infinite alternate;
}

@keyframes pulse-ring {
  0% {
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.4);
  }
  70% {
    box-shadow: 0 0 0 8px rgba(168, 85, 247, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(168, 85, 247, 0);
  }
}

.animate-pulse-ring {
  animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* Custom premium scrollbar tweaks for conversational layout */
::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: rgba(63, 63, 70, 0.4);
  border-radius: 9999px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(161, 161, 170, 0.6);
}

