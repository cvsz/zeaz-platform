# ZKBTrader safe local config
# Copy to .env and fill only on your local machine or secret manager.
# Never commit real API keys, passphrases, tokens, or private URLs.

APP_ENV=development
EXECUTION_MODE=paper
LIVE_TRADING_ENABLED=false
GLOBAL_KILL_SWITCH=false

API_HOST=127.0.0.1
API_PORT=8004
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
LOG_LEVEL=INFO

DEFAULT_STAKE_CURRENCY=USDT
DEFAULT_SYMBOLS=BTC/USDT
PAPER_STARTING_USDT=1000
PAPER_STARTING_BTC=0

DATABASE_URL=postgresql+psycopg://zkbtrader:zkbtrader_dev_password@postgres:5432/zkbtrader

# Public market-data endpoint only.
KUCOIN_BASE_URL=https://api.kucoin.com
KUCOIN_SANDBOX=false
