# === APP ===
NODE_ENV=production
PORT=3000
APP_URL=https://zlinebot.zeaz.dev

# === AUTH ===
JWT_SECRET=replace_with_at_least_32_characters_random_secret_value
SESSION_SECRET=replace_with_at_least_32_characters_random_session_secret
ENCRYPTION_KEY=replace_with_hex_32_bytes

# === DATABASE ===
DATABASE_URL=postgresql://postgres:password@db:5432/zlinebot

# === REDIS / CACHE ===
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333

# === LINE ===
LINE_CHANNEL_SECRET=replace_with_at_least_32_char_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_DEFAULT_TENANT_ID=demo
TENANT_API_KEY=demo
AUTOMATION_WORKER_MODE=embedded

# === TIKTOK ===
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://zlinebot.zeaz.dev/api/auth/tiktok/callback
TIKTOK_WEBHOOK_SECRET=your_tiktok_webhook_secret
TIKTOK_SCOPE=user.info.basic
TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK_SHOP_ACCESS_TOKEN=your_tiktok_shop_access_token

# === SaaS / BILLING ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === QUEUE ===
QUEUE_CONCURRENCY=5

# === EMAIL ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# === SECURITY ===
RATE_LIMIT=100
CORS_ORIGIN=https://zlinebot.zeaz.dev

# === AI / FEATURES ===
OLLAMA_URL=http://ollama:11434
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FEATURE_SYNC_ENABLED=false
PROMPTPAY_ID=0123456789
AI_MODE=hybrid
VECTOR_MODE=local
GPU_BURST=true
MAX_BUDGET=5

# === EDGE / WEBHOOK ===
BACKEND_WEBHOOK_URL=https://zlinebot.zeaz.dev/webhook/line
# === CLOUDFLARE ZERO TRUST ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_BASE_DOMAIN=zeaz.dev
CLOUDFLARE_TUNNEL_TOKEN=

