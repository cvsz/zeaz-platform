  <system.web>
    <compilation targetFramework="4.6.1" />
    <httpRuntime />
    <customErrors defaultRedirect="UpdatingSystem.aspx" mode="RemoteOnly">
      <error statusCode="500" redirect="UpdatingSystem.aspx" />
    </customErrors>
    <pages controlRenderingCompatibilityVersion="4.0" />
