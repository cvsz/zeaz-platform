                                      </a>
                                  </li>
                                   <li class="nav-item  ">
                                      <a href="<%= ResolveUrl("~/Question/makequestion.aspx") %>" class="nav-link ">
                                          <span class="title">สร้างข้อสอบ</span>
                                      </a>
                                  </li>
                                </ul>
                          </li>

                          <li class="nav-item  ">
                            <a href="<%= ResolveUrl("~/QA/") %>" class="nav-link nav-toggle">
                                <i class="icon-magic-wand"></i>
                                <span class="title">การประกันคุณภาพการศึกษา</span>
                            </a>
                               <ul class="sub-menu">
                                    <li class="nav-item  ">
                                      <a href="<%= ResolveUrl("~/QA_NEW/Standard1.aspx") %>" class="nav-link nav-toggle">
                                        <span class="title">มาตรฐาน 1</span>
                                    </a>
                                </li>
                                   <li class="nav-item  ">
                                     <a href="<%= ResolveUrl("~/QA_NEW/Standard2.aspx") %>" class="nav-link nav-toggle">
                                        <span class="title">มาตรฐาน 2</span>
                                    </a>
                                </li>
                                <li class="nav-item  ">
                                     <a href="<%= ResolveUrl("~/QA_NEW/survey_list.aspx") %>" class="nav-link nav-toggle">
                                        <span class="title">แบบสอบถาม</span>
                                    </a>
                                </li>
                              </ul>
                        </li>

                            <li class="nav-item  ">
                               <a href="https://docs.google.com/document/d/1rGGuIMRWv_czwKZYdT_PSFX0Qwn_jJaw6IcX45IaJYQ/edit?usp=sharing" class="nav-link nav-toggle" target="_blank">
                                   <i class="icon-star"></i>
                                   <span class="title">ข้อเสนอแนะ และ แจ้งปัญหา</span>
                               </a>

                           </li>

							<li class="heading">
                                <h3 class="uppercase">ผู้ดูแลระบบ</h3>
                            </li>
                            <li class="nav-item  ">
