                                        </a>
                                    </li>
<!--                                     <li class="nav-item  ">
                                        <a href="<%= ResolveUrl("~/Checkservice.aspx") %>" class="nav-link ">
                                            <i class=" icon-social-dropbox "></i>
                                            <span class="title">Test Service</span>
                                        </a>
                                    </li>     -->
                                </ul>
                            </li>
                             <% } %>
                           </ul>
                        <!-- END SIDEBAR MENU -->
                        <!-- END SIDEBAR MENU -->
                    </div>
                    <!-- END SIDEBAR -->
                </div>
                <!-- END SIDEBAR -->
                <!-- BEGIN CONTENT -->
                <div class="page-content-wrapper">
                    <!-- BEGIN CONTENT BODY -->
                    <div class="page-content">
                        <!-- BEGIN PAGE HEADER-->
                        <!-- BEGIN PAGE BAR -->

                            <asp:ContentPlaceHolder ID="body" runat="Server">
                            </asp:ContentPlaceHolder>

                        <!-- END PAGE BAR -->
                        <!-- END PAGE HEADER-->
