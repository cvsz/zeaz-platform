{
  "schemaVersion": 1,
  "policyId": "zlms-zero-trust-module-federation",
  "enforcement": "deny-by-default",
  "manifest": {
    "requireSignature": true,
    "requireSlsaLevel": 3,
    "requireTrustedBuilder": true,
    "requireTrustedRepository": true,
    "requireExpiry": true,
    "requireImmutableRevision": true
  },
  "remoteDomains": {
    "cspPerRemote": true,
    "trustedTypesPerRemote": true,
    "sharedGlobalState": "denied",
    "dependencySharing": "explicit-allowlist-only",
    "remoteEntryLoading": "immutable-hashed-url-only",
    "dynamicScriptCreation": "denied"
  },
  "cspTemplate": {
    "default-src": ["'none'"],
    "base-uri": ["'none'"],
    "object-src": ["'none'"],
    "frame-ancestors": ["'none'"],
    "form-action": ["'none'"],
    "script-src": ["'strict-dynamic'", "'nonce-{nonce}'", "{remoteOrigin}"],
    "connect-src": ["'self'", "{remoteOrigin}"],
    "require-trusted-types-for": ["'script'"],
    "trusted-types": ["{remoteTrustedTypesPolicy}"]
  },
  "attestation": {
    "crossDomainEvidenceRequired": true,
    "evidence": [
      "manifestDigest",
      "cspDigest",
      "dependencyDigest",
      "wasmDigest",
      "issuedAt"
    ]
  },
  "blastRadius": {
    "circuitBreakerFailureThreshold": 3,
    "halfOpenAfterMilliseconds": 30000,
    "killSwitchRequired": true,
    "quarantineRequired": true,
    "stateIsolation": "structured-clone-per-remote-map"
  }
}
