# ===================================================================
# MASTER OMEGA — AI Chat Fallback Free Provider Configuration
# apps/zchat — ZeaZ Platform
# ===================================================================
# Copy this file to .env.local and fill in your API keys.
# NEVER commit .env.local to version control.
# All values here are examples only — no real secrets.
# ===================================================================

# --- STRATEGY ORCHESTRATOR SETTINGS ---
REACT_APP_FALLBACK_CIRCUIT_BREAKER_THRESHOLD=3
REACT_APP_FALLBACK_CIRCUIT_BREAKER_COOLDOWN_MS=60000
REACT_APP_DEBUG=true

# --- PROVIDER 1: Google Gemini (FREE — 15 RPM) ---
# Sign up: https://aistudio.google.com/app/apikey
REACT_APP_GEMINI_ENABLED=true
REACT_APP_GEMINI_API_KEY=
REACT_APP_GEMINI_MODEL=gemini-2.0-flash
REACT_APP_GEMINI_TIMEOUT=20000

# --- PROVIDER 2: Groq (FREE — 30 RPM, ultra-fast LLaMA) ---
# Sign up: https://console.groq.com/keys
REACT_APP_GROQ_ENABLED=true
REACT_APP_GROQ_API_KEY=
REACT_APP_GROQ_MODEL=llama-3.3-70b-versatile
REACT_APP_GROQ_TIMEOUT=15000

# --- PROVIDER 3: Cohere (FREE trial, 100 req/month free) ---
# Sign up: https://dashboard.cohere.com/api-keys
REACT_APP_COHERE_ENABLED=true
REACT_APP_COHERE_API_KEY=
REACT_APP_COHERE_MODEL=command-r
REACT_APP_COHERE_TIMEOUT=25000

# --- PROVIDER 4: Hugging Face (FREE Inference API) ---
# Sign up: https://huggingface.co/settings/tokens
REACT_APP_HUGGINGFACE_ENABLED=true
REACT_APP_HUGGINGFACE_API_KEY=
REACT_APP_HUGGINGFACE_MODEL=Qwen/Qwen3-0.6B
REACT_APP_HUGGINGFACE_MODEL_CANDIDATES=Qwen/Qwen3-0.6B,TinyLlama/TinyLlama-1.1B-Chat-v1.0,Qwen/Qwen2.5-1.5B-Instruct,microsoft/phi-2,openai-community/gpt2,Qwen/Qwen3-4B,mistralai/Mistral-7B-Instruct-v0.3,Qwen/Qwen3-8B
REACT_APP_HUGGINGFACE_TIMEOUT=30000

# --- PROVIDER 5: OpenRouter (FREE :free models available) ---
# Sign up: https://openrouter.ai/keys
REACT_APP_OPENROUTER_ENABLED=true
REACT_APP_OPENROUTER_API_KEY=
REACT_APP_OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
REACT_APP_OPENROUTER_TIMEOUT=25000

# --- PROVIDER 6: Mistral AI (FREE tier) ---
# Sign up: https://console.mistral.ai/api-keys
REACT_APP_MISTRAL_ENABLED=true
REACT_APP_MISTRAL_API_KEY=
REACT_APP_MISTRAL_MODEL=mistral-small-latest
REACT_APP_MISTRAL_TIMEOUT=20000

# --- PROVIDER 7: Together AI (FREE $25 credit on signup) ---
# Sign up: https://api.together.xyz/settings/api-keys
REACT_APP_TOGETHER_ENABLED=false
REACT_APP_TOGETHER_API_KEY=
REACT_APP_TOGETHER_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo
REACT_APP_TOGETHER_TIMEOUT=25000

# --- PROVIDER 8: Ollama LOCAL (FREE — requires local install) ---
# Install: https://ollama.ai — then run: ollama pull llama3.2
# Disabled by default since it requires a local server.
REACT_APP_OLLAMA_ENABLED=false
REACT_APP_OLLAMA_BASE_URL=http://localhost:11434
REACT_APP_OLLAMA_MODEL=llama3.2
REACT_APP_OLLAMA_TIMEOUT=60000

# --- PROVIDER 9: Smart Offline (ALWAYS available — no key needed) ---
REACT_APP_OFFLINE_ENABLED=true

# --- FEATURE FLAGS ---
REACT_APP_ENABLE_CHAT_HISTORY=true
REACT_APP_ENABLE_EXPORT=true
REACT_APP_ENABLE_RATE_LIMIT=true
REACT_APP_RATE_LIMIT_REQUESTS=20
REACT_APP_RATE_LIMIT_WINDOW_MS=60000
REACT_APP_MAX_HISTORY_TURNS=10
REACT_APP_SHOW_PROVIDER_BADGE=true
REACT_APP_SHOW_LATENCY=true
REACT_APP_MAX_MESSAGES=100

# --- DEVELOPMENT ---
NODE_ENV=development
