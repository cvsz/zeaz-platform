# ZeaZ Platform - Environment Configuration Example
# Copy this file to .env and fill in the required values.
# DO NOT COMMIT THE ACTUAL .env FILE.

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=example-account-id
CLOUDFLARE_ZONE_ID=example-zone-id
CLOUDFLARE_API_TOKEN=example-api-token
CLOUDFLARE_DNS_TOKEN=example-dns-token
CLOUDFLARE_WORKERS_TOKEN=example-workers-token
CLOUDFLARE_ZT_TOKEN=example-zt-token
CLOUDFLARE_WAF_TOKEN=example-waf-token
CLOUDFLARE_TUNNEL_TOKEN=example-tunnel-token
CLOUDFLARE_R2_TOKEN=example-r2-token
CLOUDFLARE_AI_GATEWAY_SLUG=example-gateway-slug

# Identity Provider Configuration
IDENTITY_PROVIDER_TYPE=saml
IDENTITY_PROVIDER_VENDOR=zeazdev-ai-saml
IDENTITY_PROVIDER_METADATA_URL=https://example.invalid/metadata

# Runtime Environment
ENVIRONMENT=development
REGION=us-east-1
PRIMARY_DOMAIN=example.invalid

# Database/Infrastructure
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
TERRAFORM_BACKEND_TYPE=s3
TERRAFORM_STATE_BUCKET=example-tf-state-bucket
TERRAFORM_LOCK_TABLE=example-tf-lock-table

# Security
SOPS_AGE_KEY=age1example...
SECRET_ROTATION_INTERVAL=90
JWT_SECRET=example-jwt-secret

# Cloudflare Plan
CLOUDFLARE_PLAN_TIER=free
