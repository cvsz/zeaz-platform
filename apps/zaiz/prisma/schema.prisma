// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// API keys for rate-limited access to the zLM-CLI backend.
model ApiKey {
  id           String   @id @default(cuid())
  /// The actual key string, prefixed with `zlm-` and stored hashed (sha256).
  keyHash      String   @unique
  /// Last 4 chars of the raw key, shown in the UI for identification.
  lastFour     String
  name         String
  /// Max requests per hour. 0 = unlimited.
  rateLimitPerHour Int  @default(60)
  /// Total requests made with this key.
  usageCount   Int      @default(0)
  /// Whether the key can be used.
  active       Boolean  @default(true)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([keyHash])
  @@index([active])
}

/// Payment orders for the payment gateway.
model PaymentOrder {
  id          String   @id @default(cuid())
  /// Public order reference shown to the customer.
  reference   String   @unique
  /// Customer email.
  email       String
  /// Plan id: starter | pro | team | enterprise.
  plan        String
  /// Amount in cents (USD).
  amountCents Int
  currency    String   @default("usd")
  /// pending | paid | failed | refunded.
  status      String   @default("pending")
  /// Payment provider: mock | stripe | paypal.
  provider    String   @default("mock")
  /// Provider transaction id (if any).
  providerTxId String?
  /// Credits granted (e.g. API requests).
  credits     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  paidAt      DateTime?

  @@index([status])
  @@index([email])
}

/// Roles for role-based access control (RBAC).
model Role {
  id          String   @id @default(cuid())
  /// Role name: admin | developer | viewer | guest.
  name        String   @unique
  /// Comma-separated permission keys.
  permissions String
  /// Whether the role is active.
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// API key → role assignments (a key can have one role).
model ApiKeyRole {
  id        String   @id @default(cuid())
  apiKeyId  String
  roleName  String
  createdAt DateTime @default(now())

  @@unique([apiKeyId, roleName])
  @@index([apiKeyId])
}

/// User profiles — created on login via API key, track plan + credits + limits.
model UserProfile {
  id            String   @id @default(cuid())
  /// The API key hash this profile belongs to.
  keyHash       String   @unique
  email         String?
  name          String?
  /// Plan: free | starter | pro | team | enterprise.
  plan          String   @default("free")
  /// Remaining credits (requests).
  credits       Int      @default(100)
  /// Total tokens used (input + output).
  tokensUsed    Int      @default(0)
  /// Total requests made.
  requestCount  Int      @default(0)
  /// Internet access toggle (for web search/research).
  internetEnabled Boolean @default(true)
  /// Memory enabled toggle.
  memoryEnabled Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?

  @@index([keyHash])
}

/// Usage records — one per API request, for billing + analytics.
model UsageRecord {
  id          String   @id @default(cuid())
  keyHash     String
  /// Endpoint: cli | agent | plan | image | video | search | research | sandbox | mcp.
  endpoint    String
  model       String?
  /// Input tokens (estimated).
  inputTokens Int      @default(0)
  /// Output tokens (estimated).
  outputTokens Int     @default(0)
  /// Duration in ms.
  durationMs  Int      @default(0)
  /// Success status.
  ok          Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([keyHash])
  @@index([endpoint])
  @@index([createdAt])
}

/// Memory entries — persistent facts/notes per user.
model Memory {
  id        String   @id @default(cuid())
  keyHash   String
  /// Memory category: fact | preference | note | context.
  category  String   @default("note")
  /// The memory content.
  content   String
  /// Importance 1-5.
  importance Int     @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyHash])
  @@index([category])
}

/// Invoices — billing records.
model Invoice {
  id          String   @id @default(cuid())
  keyHash     String
  /// Invoice number (human-readable).
  number      String   @unique
  /// Plan or usage charge.
  type        String   @default("plan")
  description String
  /// Amount in cents.
  amountCents Int
  currency    String   @default("usd")
  /// pending | paid | void | refunded.
  status      String   @default("pending")
  /// Billing period.
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  paidAt      DateTime?

  @@index([keyHash])
  @@index([status])
}