FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/zeaznode ./cmd/zeaznode

FROM alpine:3.22
RUN adduser -D -H zeaz
USER zeaz
COPY --from=build /out/zeaznode /usr/local/bin/zeaznode
EXPOSE 8090
ENTRYPOINT ["/usr/local/bin/zeaznode"]
