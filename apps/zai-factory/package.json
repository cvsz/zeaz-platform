{
  "name": "@zeaz/zai-factory",
  "version": "0.1.0",
  "description": "Local-first AI Factory system for ZEAZ Platform",
  "main": "src/index.js",
  "bin": {
    "zai-factory": "./bin/zai-factory.js"
  },
  "scripts": {
    "dev": "node server.mjs --host 127.0.0.1 --port 4191",
    "start": "node server.mjs --host 127.0.0.1 --port 4191",
    "validate": "node scripts/validate-zai-factory.mjs",
    "skills:scan": "node scripts/zai-factory-skills-installer.mjs",
    "skills:install": "node scripts/zai-factory-skills-installer.mjs --apply --symlink",
    "skills:install:copy": "node scripts/zai-factory-skills-installer.mjs --apply --copy",
    "skills:scan:all": "node scripts/zai-factory-skills-installer.mjs --include-global",
    "duplicates:scan": "node scripts/zai-factory-skills-installer.mjs --include-global",
    "duplicates:clean": "node scripts/clean-ai-asset-duplicates.mjs",
    "duplicates:clean:apply": "node scripts/clean-ai-asset-duplicates.mjs --apply",
    "duplicates:tree": "node scripts/tree-ai-asset-duplicates.mjs",
    "duplicates:tree:conflicts": "node scripts/tree-ai-asset-duplicates.mjs --conflicts",
    "duplicates:tree:same": "node scripts/tree-ai-asset-duplicates.mjs --same-sha",
    "duplicates:clean:lower": "node scripts/clean-ai-asset-duplicates.mjs --clean-lower-priority",
    "duplicates:clean:lower:apply": "node scripts/clean-ai-asset-duplicates.mjs --apply --clean-lower-priority",
    "build": "node scripts/validate-zai-factory.mjs",
    "registry": "node bin/zai-factory.js registry",
    "apps": "node bin/zai-factory.js apps"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.19.0"
  },
  "type": "module"
}
