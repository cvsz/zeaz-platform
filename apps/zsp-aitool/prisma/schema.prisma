generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  THREADS
  X
}

enum Tone {
  CASUAL
  FRIENDLY
  PROFESSIONAL
  SALES
  REVIEW
}

enum Language {
  TH
  EN
}

enum SubscriptionPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CsvImportJobStatus {
  PENDING
  RUNNING
  CANCEL_REQUESTED
  CANCELLED
  COMPLETED
  FAILED
}

enum CsvImportJobKind {
  SHOPEE_PRODUCT_FEED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  password           String?
  planTier           PlanTier            @default(FREE)
  products           Product[]
  contentGenerations ContentGeneration[]
  aiContentQueueJobs AIContentQueueJob[]
  affiliateLinks     AffiliateLink[]
  shopeeAffiliateSocialDrafts ShopeeAffiliateSocialDraft[]
  shopeeAffiliateSocialDraftVersions ShopeeAffiliateSocialDraftVersion[]
  shopeeAffiliateIngestions ShopeeAffiliateIngestion[]
  contentTemplates   ContentTemplate[]
  promptPresets      PromptPreset[]
  ocrJobs            OCRJob[]
  hyperFrameRenderJobs HyperFrameRenderJob[]
  hyperFrameScriptGenerations HyperFrameScriptGeneration[]
  hyperFrameRenderShares HyperFrameRenderShare[]
  platformPosts      PlatformPost[]
  settings           UserSetting?
  apiUsageLogs       APIUsageLog[]
  hyperFrameSocialExportAuditEvents HyperFrameSocialExportAuditEvent[]
  feedbackSubmissions FeedbackSubmission[]
  orgMemberships     OrgMembership[]
  csvImportJobs      CsvImportJob[]
  productDuplicateGroups ProductDuplicateGroup[]
  exportJobs          ExportJob[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model FeedbackSubmission {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  category  String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([deletedAt])
}

enum OrgRole {
  VIEWER
  EDITOR
  ADMIN
}

model Organization {
  id                   String               @id @default(cuid())
  name                 String
  memberships          OrgMembership[]
  hyperFrameRenderJobs HyperFrameRenderJob[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model OrgMembership {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole      @default(VIEWER)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

model ObservabilityEvent {
  id         String   @id @default(cuid())
  level      String
  source     String
  event      String
  durationMs Int?
  status     String?
  metadata   Json?
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  @@index([level, createdAt])
  @@index([source, event, createdAt])
}

model Product {
  id                 String              @id @default(cuid())
  userId             String
  title              String
  price              Decimal             @db.Decimal(12, 2)
  currency           String              @default("THB")
  originalUrl        String
  affiliateUrl       String?
  shopName           String?
  rating             Decimal?            @db.Decimal(3, 2)
  soldCount          Int?
  description        String?
  category           String?
  rawMetadata        Json?
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  images             ProductImage[]
  affiliateLinks     AffiliateLink[]
  shopeeAffiliateIngestions ShopeeAffiliateIngestion[]
  shopeeAffiliateSocialDrafts ShopeeAffiliateSocialDraft[]
  contentGenerations ContentGeneration[]
  aiContentQueueJobs AIContentQueueJob[]
  sourceSimilarities SimilarProduct[]    @relation("SourceProduct")
  relatedSimilarTo   SimilarProduct[]    @relation("RelatedProduct")
  platformPosts      PlatformPost[]
  ocrJobs            OCRJob[]
  hyperFrameRenderJobs HyperFrameRenderJob[]
  hyperFrameScriptGenerations HyperFrameScriptGeneration[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@index([userId, createdAt])
  @@index([userId, category])
  @@index([userId, deletedAt])
  @@index([userId, shopName])
  @@index([userId, affiliateUrl])
  @@index([userId, createdAt, id])
  @@unique([userId, originalUrl])
}



model ProductDuplicateGroup {
  id                 String   @id @default(cuid())
  userId             String
  status             String   @default("PENDING_REVIEW")
  canonicalProductId String?
  productIds         String[]
  score              Decimal? @db.Decimal(5, 2)
  reason             Json?
  reviewedAt         DateTime?
  mergedAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([productId, sortOrder])
  @@index([deletedAt])
}

model AffiliateLink {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  platform     Platform
  originalUrl  String
  affiliateUrl String
  trackingCode String?
  clickCount   Int      @default(0)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopeeAffiliateSocialDrafts ShopeeAffiliateSocialDraft[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([userId, platform])
  @@index([productId])
  @@index([deletedAt])
}

enum ShopeeAffiliateIngestionSource {
  MANUAL
  CSV
  EXTENSION
  OPEN_API_FUTURE
}

enum ShopeeAffiliateIngestionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  IMPORTED
  FAILED
}

enum ShopeeAffiliateSocialChannel {
  FACEBOOK
  THREADS
  X
  INSTAGRAM
  TIKTOK
  YOUTUBE_SHORTS
}

enum ShopeeAffiliateSocialDraftStatus {
  DRAFT
  READY_FOR_REVIEW
  COPIED
  ARCHIVED
  REJECTED
}

model ShopeeAffiliateIngestion {
  id                String   @id @default(cuid())
  userId            String
  productId         String?
  source            ShopeeAffiliateIngestionSource
  status            ShopeeAffiliateIngestionStatus @default(PENDING_REVIEW)
  affiliateUrl      String?
  productUrl        String?
  title             String?
  campaignNote      String?
  price             Decimal? @db.Decimal(12, 2)
  normalizedPayload Json?
  errorSummary      String?
  rowIndex          Int?
  reviewedAt        DateTime?
  importedAt        DateTime?
  failedAt          DateTime?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  socialDrafts      ShopeeAffiliateSocialDraft[]

  @@index([userId, status, createdAt])
  @@index([source, status])
  @@index([productId])
  @@index([deletedAt])
}

model ShopeeAffiliateSocialDraft {
  id              String                           @id @default(cuid())
  userId          String
  ingestionId     String
  productId       String?
  affiliateLinkId String?
  channel         ShopeeAffiliateSocialChannel
  status          ShopeeAffiliateSocialDraftStatus @default(DRAFT)
  title           String?
  content         String
  disclosure      String?
  hashtags        String?
  version         Int                              @default(1)
  metadata        Json?
  source          String?
  copiedAt        DateTime?
  reviewedAt      DateTime?
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt

  user            User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingestion       ShopeeAffiliateIngestion         @relation(fields: [ingestionId], references: [id], onDelete: Cascade)
  product         Product?                         @relation(fields: [productId], references: [id], onDelete: SetNull)
  affiliateLink   AffiliateLink?                   @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  versions        ShopeeAffiliateSocialDraftVersion[]

  @@index([userId, ingestionId, channel, createdAt])
  @@index([userId, status, createdAt])
}

model ShopeeAffiliateSocialDraftVersion {
  id        String                     @id @default(cuid())
  userId    String
  draftId   String
  version   Int
  content   String
  editor    String?
  source    String?
  createdAt DateTime                   @default(now())

  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft     ShopeeAffiliateSocialDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, version])
  @@index([userId, createdAt])
}


model CsvImportJob {
  id              String           @id @default(cuid())
  userId          String
  kind            CsvImportJobKind @default(SHOPEE_PRODUCT_FEED)
  status          CsvImportJobStatus @default(PENDING)
  sourceFileName  String
  sourceFilePath  String
  totalBytes      BigInt?
  processedRows   Int              @default(0)
  importedRows    Int              @default(0)
  rejectedRows    Int              @default(0)
  failedRows      Int              @default(0)
  lastRowNumber   Int              @default(0)
  retryOfJobId    String?
  lastError       String?
  sampleRejected  Json?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
}


model AIContentQueueJob {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  kind        String
  platform    Platform?
  tone        Tone?
  language    Language  @default(TH)
  input       Json?
  output      Json?
  status      String    @default("PENDING")
  attempt     Int       @default(0)
  maxAttempts Int       @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  errorSummary String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@index([productId, createdAt])
  @@index([deletedAt])
}

model ExportJob {
  id             String   @id @default(cuid())
  userId         String
  type           String
  format         String
  status         String   @default("PENDING")
  filters        Json?
  outputPath     String?
  outputFileName String?
  rowCount       Int      @default(0)
  errorSummary   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completedAt    DateTime?
  failedAt       DateTime?
  deletedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model ContentGeneration {
  id         String    @id @default(cuid())
  userId     String
  productId  String
  platform   Platform
  tone       Tone
  language   Language
  prompt     String
  output     Json
  tokenUsage Int?
  status     JobStatus @default(PENDING)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  platformPosts PlatformPost[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([userId, createdAt])
  @@index([productId])
  @@index([platform, status])
  @@index([deletedAt])
}

model ContentTemplate {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  platform    Platform
  tone        Tone?
  language    Language
  template    String
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId, platform, language])
  @@index([userId, isActive])
  @@index([deletedAt])
}

model PromptPreset {
  id        String    @id @default(cuid())
  userId    String
  name      String
  platform  Platform?
  tone      Tone?
  language  Language?
  prompt    String
  isDefault Boolean   @default(false)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, platform])
  @@index([deletedAt])
}

model OCRJob {
  id            String    @id @default(cuid())
  userId        String
  productId     String?
  imageUrl      String
  extractedText String?
  confidence    Float?
  status        JobStatus @default(PENDING)
  errorMessage  String?
  rawResult     Json?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([userId, status, createdAt])
  @@index([deletedAt])
}

model SimilarProduct {
  id               String   @id @default(cuid())
  sourceProductId  String
  relatedProductId String
  score            Int
  reason           String?
  sourceProduct    Product  @relation("SourceProduct", fields: [sourceProductId], references: [id], onDelete: Cascade)
  relatedProduct   Product  @relation("RelatedProduct", fields: [relatedProductId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@unique([sourceProductId, relatedProductId])
  @@index([sourceProductId, score])
  @@index([relatedProductId])
  @@index([deletedAt])
}

model PlatformPost {
  id                  String             @id @default(cuid())
  userId              String
  productId           String
  contentGenerationId String?
  platform            Platform
  caption             String
  hashtags            String[]
  postedAt            DateTime?
  externalPostId      String?
  status              JobStatus          @default(PENDING)
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  product             Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  contentGeneration   ContentGeneration? @relation(fields: [contentGenerationId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([userId, platform, createdAt])
  @@index([productId])
  @@index([deletedAt])
}

model UserSetting {
  id                  String    @id @default(cuid())
  userId              String    @unique
  defaultLanguage     Language  @default(TH)
  defaultTone         Tone      @default(FRIENDLY)
  defaultPlatform     Platform?
  affiliateDisclosure String?
  defaultHashtags     String[]
  ctaStyle            String?
  subscriptionPlan    SubscriptionPlan @default(FREE)
  brandColors         String[]
  fontPreference      String?
  logoUrl             String?
  watermarkText       String?
  defaultAspectRatio  String?
  defaultCTA          String?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  @@index([deletedAt])
}

model APIUsageLog {
  id            String    @id @default(cuid())
  userId        String
  provider      String
  endpoint      String
  model         String?
  requestToken  Int?
  responseToken Int?
  totalToken    Int?
  costUsd       Decimal?  @db.Decimal(12, 6)
  status        JobStatus
  metadata      Json?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([userId, createdAt])
  @@index([provider, endpoint])
  @@index([status])
  @@index([deletedAt])
}


enum PlanTier {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum RenderJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}


model HyperFrameScriptGeneration {
  id             String   @id @default(cuid())
  userId         String
  productId      String
  platform       String
  tone           String
  language       String
  requestPayload Json
  script         String
  beats          Json
  captions       Json
  metadata       Json
  disclosure     String?
  warnings       String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([productId])
}

model HyperFrameRenderJob {
  id                  String   @id @default(cuid())
  userId              String
  orgId               String?
  productId           String?
  contentGenerationId String?
  status              RenderJobStatus @default(PENDING)
  compositionHtml     String
  compositionMetadata Json?
  outputPath          String?
  outputUrl           String?
  outputSizeBytes     BigInt?
  errorMessage        String?
  durationSeconds     Int?
  width               Int?
  height              Int?
  attempts            Int      @default(0)
  lockedAt            DateTime?
  lockedBy            String?
  startedAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  shares              HyperFrameRenderShare[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@index([orgId, status, createdAt])
}

model HyperFrameRenderShare {
  id          String   @id @default(cuid())
  renderJobId String
  ownerUserId String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  renderJob   HyperFrameRenderJob @relation(fields: [renderJobId], references: [id], onDelete: Cascade)
  owner       User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([renderJobId])
  @@index([ownerUserId, createdAt])
  @@index([expiresAt])
}


model HyperFrameSocialExportAuditEvent {
  id          String   @id @default(cuid())
  userId      String
  renderJobId String
  provider    String
  eventType   String
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([renderJobId])
  @@index([provider, eventType])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  status      String   @default("SUCCESS")
  ipHash      String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}
