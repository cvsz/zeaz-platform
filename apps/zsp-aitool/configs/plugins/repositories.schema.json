{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Zeaz Platform Plugin Repository Manifest",
  "type": "object",
  "properties": {
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "app_id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "repo": {
            "type": "string"
          },
          "mode": {
            "enum": ["embedded", "external"]
          },
          "path": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "source": {
            "type": "object",
            "properties": {
              "branch": { "type": "string" },
              "remote": { "type": "string" },
              "sync_strategy": { "type": "string" }
            }
          },
          "runtime": {
            "type": "object",
            "properties": {
              "type": {
                "enum": ["node", "python", "docker", "static", "mixed"]
              },
              "dev_ports": { "type": "array", "items": { "type": "integer" } },
              "prod_ports": { "type": "array", "items": { "type": "integer" } },
              "health_urls": { "type": "array", "items": { "type": "string" } },
              "start_commands": { "type": "array", "items": { "type": "string" } },
              "stop_commands": { "type": "array", "items": { "type": "string" } },
              "validate_commands": { "type": "array", "items": { "type": "string" } }
            }
          },
          "cloudflare": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "zone": { "type": "string" },
              "hostnames": { "type": "array", "items": { "type": "string" } },
              "tunnel_target": { "type": "string" },
              "access_policy": { "type": "string" },
              "terraform_enabled": { "type": "boolean" },
              "cost_lock_required": { "type": "boolean" }
            }
          },
          "plugin_capabilities": {
            "type": "object",
            "properties": {
              "dashboard": { "type": "boolean" },
              "api": { "type": "boolean" },
              "worker": { "type": "boolean" },
              "scheduler": { "type": "boolean" },
              "marketplace": { "type": "boolean" },
              "payments": { "type": "boolean" },
              "ai": { "type": "boolean" },
              "storage": { "type": "boolean" },
              "analytics": { "type": "boolean" },
              "cloudflare_operator": { "type": "boolean" }
            }
          },
          "safety": {
            "type": "object",
            "properties": {
              "dry_run_default": { "type": "boolean" },
              "requires_confirmation": { "type": "boolean" },
              "no_paid_cloudflare_features": { "type": "boolean" },
              "secret_keys_forbidden": { "type": "boolean" },
              "protected_files": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "required": ["app_id", "repo", "mode", "path", "enabled"]
      }
    }
  }
}
